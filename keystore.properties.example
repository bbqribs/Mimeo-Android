# Copy this file to keystore.properties in the repo root.
# Keep keystore.properties untracked and keep the keystore file outside every git tree.
# Use forward slashes or escaped backslashes for Windows paths.

storeFile=C:/path/outside/git/mimeo-android-release.jks
storePassword=<release-keystore-password>
keyAlias=mimeo-household-release
keyPassword=<release-key-password>
