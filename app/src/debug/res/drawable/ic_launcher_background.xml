<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-variant adaptive launcher background: full-bleed amber (#C2410C) instead of the
  production lilac (#6B49CC). The debug build installs alongside production (applicationId
  suffix ".debug") and registers the same ACTION_SEND share handler, so the two apps appear
  together in the share sheet. The "Mimeo Debug" label alone is easy to miss at share-sheet
  size, where the icon dominates — this colour swap makes the target unmistakable.
  The white "M" foreground is shared and stays legible against amber.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#C2410C"
        android:pathData="M0,0h108v108h-108z" />
</vector>
