<?xml version="1.0" encoding="utf-8"?>
<!--
  Scoped network security config (release baseline).

  Replaces the former app-wide android:usesCleartextTraffic="true". Cleartext HTTP is
  denied by default so ordinary public hostnames require HTTPS. The preferred remote
  path is HTTPS over Tailscale (https://<machine>.<tailnet>.ts.net), which always works
  because HTTPS is never restricted here.

  Cleartext is permitted only for loopback / emulator-host development targets, which can
  never be a public man-in-the-middle target:
    - 10.0.2.2  : Android emulator alias for the host loopback
    - 127.0.0.1 : device loopback
    - localhost : device loopback

  Android network security config matches exact hosts only (no CIDR ranges), so arbitrary
  private LAN (192.168/10/172.16-31) and Tailscale CGNAT (100.64.0.0/10) HTTP addresses
  cannot be enumerated safely without over-permitting. Those development-only cleartext
  paths are handled in the debug-build override at app/src/debug/res/xml/network_security_config.xml,
  which never ships in release builds.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />

    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
